# FLUX.1 Schnell — Black Forest Labs' distilled 4-step image model (1024x1024).
# Source: city96/FLUX.1-schnell-gguf
# Recommended: 16 GB VRAM at Q4_0 (~8.1 GB). Schnell is distilled — keep steps=4, cfg_scale=0.
version: 1
name: flux-schnell
backend: sd
mode: server
model:
  source: huggingface
  repo: city96/FLUX.1-schnell-gguf
  file: flux1-schnell-Q4_0.gguf       # 8.1GB — recommended for 16GB VRAM
  # file: flux1-schnell-Q8_0.gguf     # 16.0GB — full precision, very tight on 16GB VRAM
  download:
    resume: true
    connections: 4
server:
  host: 127.0.0.1
  port: 8091
sd:
  diffusion_model: "hf://city96/FLUX.1-schnell-gguf/flux1-schnell-Q4_0.gguf"
  width: 1024
  height: 1024
  steps: 4              # schnell is distilled for 4 steps — do not increase
  cfg_scale: 0.0        # schnell: classifier-free guidance is disabled
  sampling_method: euler
  seed: -1
hardware_profiles:
  nvidia:
    n_gpu_layers: 99
    cuda: true
  apple_silicon:
    n_gpu_layers: 99
    metal: true
  cpu:
    n_gpu_layers: 0
