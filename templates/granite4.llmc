# IBM Granite 4.0 H Tiny — compact hybrid (Mamba + attention) chat model.
# Source: unsloth/granite-4.0-h-tiny-GGUF
# Recommended: 16 GB VRAM at Q6_K_XL (~5.9 GB); Q4_K_M (~4.2 GB) for headroom.
version: 1
name: granite4
backend: llama
mode: server
model:
  source: huggingface
  repo: unsloth/granite-4.0-h-tiny-GGUF
  file: granite-4.0-h-tiny-UD-Q6_K_XL.gguf    # 5.9GB — recommended for 16GB VRAM
  # file: granite-4.0-h-tiny-UD-Q8_K_XL.gguf  # 7.7GB — higher quality
  # file: granite-4.0-h-tiny-Q4_K_M.gguf       # 4.2GB — standard Q4 alternative
  download:
    resume: true
server:
  host: 127.0.0.1
  port: 8080
hardware_profiles:
  nvidia:
    n_gpu_layers: 99
    cuda: true
  apple_silicon:
    n_gpu_layers: 99
    metal: true
  cpu:
    n_gpu_layers: 0
