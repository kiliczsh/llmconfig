# Google Gemma 4 E4B Instruct — efficient general-purpose chat (~4B effective params).
# Source: unsloth/gemma-4-E4B-it-GGUF
# Recommended: 16 GB VRAM at Q8_K_XL (~4.4 GB) — comfortable headroom for long contexts.
version: 1
name: gemma
backend: llama
mode: server
model:
  source: huggingface
  repo: unsloth/gemma-4-E4B-it-GGUF
  file: gemma-4-E4B-it-UD-Q8_K_XL.gguf            # 4.4GB — recommended for 16GB VRAM
  # file: gemma-4-E4B-it-UD-Q6_K_XL.gguf          # 3.4GB — faster inference
  # file: gemma-4-E4B-it-Q4_K_M.gguf              # 2.4GB — lightest option
  download:
    resume: true
server:
  host: 127.0.0.1
  port: 8080
hardware_profiles:
  nvidia:
    n_gpu_layers: 99
    cuda: true
  apple_silicon:
    n_gpu_layers: 99
    metal: true
  cpu:
    n_gpu_layers: 0
